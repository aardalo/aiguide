    "neo4j-driver": "^6.0.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^1.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.1.1",
    "prisma": "^5.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.1.0"
  }
}
